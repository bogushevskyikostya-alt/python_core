# Завдання 1
import turtle

t = turtle.Turtle()
t.speed(3)

t.color("red")
for _ in range(4):
    t.forward(100)
    t.right(90)

t.penup()
t.forward(150)
t.pendown()

t.color("green")
for _ in range(3):
    t.forward(100)
    t.left(120)

t.penup()
t.forward(150)
t.pendown()

t.color("blue")
for _ in range(5):
    t.forward(100)
    t.right(72)

turtle.done()

# Завдання 2 (будиночок)
import turtle

t = turtle.Turtle()
t.speed(3)

for _ in range(4):
    t.forward(100)
    t.left(90)

t.left(45)
t.begin_fill()
t.color("red")

for _ in range(3):
    t.forward(100)
    t.left(120)

t.end_fill()

turtle.done()

